# Ensemble environment variables (names only -- copy to .env.local and fill in).
# .env.local is gitignored; never commit real values.

# Supabase backbone (project region: eu-central-1 / Frankfurt).
# URL + anon key are public and used by the browser client; the service-role
# key bypasses RLS and is SERVER-ONLY (Route Handlers / Server Actions / workers).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic -- chat (Sonnet), gate (Haiku), research + paper (Opus).
ANTHROPIC_API_KEY=

# Embeddings (Voyage-3.5) and reranker (Cohere Rerank 3.5).
VOYAGE_API_KEY=
COHERE_API_KEY=

# LinkedIn "Sign in with LinkedIn" OIDC app.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Contact for the scholarly-API polite pools (OpenAlex/Crossref User-Agent mailto).
OPENALEX_MAILTO=

# Python OR-Tools CP-SAT team-assembly worker (POST /assemble).
ASSEMBLY_WORKER_URL=
# Shared secret for scheduler-triggered assembly runs (bearer on /api/teams/assemble).
ASSEMBLY_TRIGGER_SECRET=

# Postgres URI for the pg-boss job queue (research worker). Falls back to SUPABASE_DB_URL.
DATABASE_URL=

# Founder account (operator console access + auto-membership in every room).
# Set to the email of the account that should have operator/founder rights.
NEXT_PUBLIC_FOUNDER_EMAIL=
